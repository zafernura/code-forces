import sys
input = sys.stdin.readline

t = int(input())
for _ in range(t):
    n, c = input().split()
    n = int(n)
    s = input().strip()
    
    s = s + s
    
    g_pos = []
    for i in range(2 * n):
        if s[i] == 'g':
            g_pos.append(i)
    
    res = 0
    j = 0
    
    for i in range(n):
        if s[i] == c:
            while g_pos[j] < i:
                j += 1
            res = max(res, g_pos[j] - i)
    
    print(res)
